# ====================
# SERVEUR
# ====================
PORT=5000
NODE_ENV=development
API_PREFIX=/api
CORS_ORIGIN=http://localhost:5173

# ====================
# BASE DE DONNÉES PostgreSQL
# ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=djorssi_express_db
DB_USER=djorssi_user
DB_PASSWORD=djorssi123!

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0
REDIS_CACHE_TTL=3600  # 1 heure par défaut

# ====================
# EMAIL CONFIGURATION
# ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe
EMAIL_FROM=noreply@djorssi-express.com
EMAIL_ENABLED=true

# ====================
# SMS CONFIGURATION
# ====================
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=votre_account_sid
TWILIO_AUTH_TOKEN=votre_auth_token
TWILIO_PHONE_NUMBER=+2250123456789

# Options du pool de connexions (valeurs par défaut)
DB_POOL_MAX=5
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# ====================
# JWT (JSON Web Token)
# ====================
JWT_SECRET=djorssi-express-super-secret-key-2025-very-secure
JWT_EXPIRES_IN=7d

# (Optionnel) Si vous préférez utiliser une URL complète
# DATABASE_URL=postgresql://mon_user:mon_mot_de_passe@localhost:5432/ma_base