{
  "name": "djorssi-express",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:build": "docker-compose build",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:dev:logs": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:clean": "docker-compose down -v && docker system prune -f",
    "docker:restart": "docker-compose restart",
    "docker:exec": "docker exec -it djorssi_app sh",
    "docker:psql": "docker exec -it djorssi_postgres psql -U djorssi_user -d djorssi_express_db",
    "docker:redis": "docker exec -it djorssi_redis redis-cli",
    "migrate": "node migrate.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@sequelize/postgres": "^7.0.0-alpha.48",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "handlebars": "^4.7.9",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "pug": "^3.0.4",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.3",
    "twilio": "^6.0.2",
    "zod": "^4.4.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/bull": "^3.15.9",
    "@types/ioredis": "^4.28.10",
    "nodemon": "^3.1.14"
    
  }
}
